{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Rome",
  "schedule": ["before 3pm on friday"],
  "prConcurrentLimit": 10,
  "dependencyDashboard": false,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all non-breaking updates into a single PR",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "matchJsonata": ["isBreaking != true"],
      "groupName": "all non-breaking",
      "automerge": true
    },
    {
      "description": "Breaking updates: separate PRs, no automerge",
      "matchJsonata": ["isBreaking == true"],
      "automerge": false,
      "addLabels": ["major"]
    }
  ]
}
